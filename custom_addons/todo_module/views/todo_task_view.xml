<odoo>

    <!-- Tree View -->
    <record id="todo_task_tree_view" model="ir.ui.view">
        <field name="name">todo task tree</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <tree decoration-danger="status in ('completed', 'closed')" decoration-success="status == 'in_progress'" decoration-muted="status == 'new'">
                <field name="name"/>
                <field name="description"/>
                <field name="due_date"/>
                <field name="assign_to"/>
                <field name="estimated_time"/>
                <field name="total_time"/>
                <field name="status"/>
                <field name="is_late" invisible="1"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="todo_task_form_view" model="ir.ui.view">
        <field name="name">todo task form</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <!-- Visual Indicators for Locked Tasks -->
                    <widget name="web_ribbon" title="LOCKED - Read Only" bg_color="text-bg-danger" invisible="status not in ('completed', 'closed')"/>
                    <widget name="web_ribbon" title="Completed" bg_color="text-bg-success" invisible="status != 'completed'"/>
                    <widget name="web_ribbon" title="Closed" bg_color="text-bg-dark" invisible="status != 'closed'"/>

                    <header>
                        <!-- Unlock/Revert Buttons for Locked Tasks -->
                        <button name="action_new" type="object" class="btn-warning" string="🔓 Revert to New"
                                invisible="status != 'completed'"/>
                        <button name="action_in_progress" type="object" class="btn-warning" string="🔓 Revert to In Progress"
                                invisible="status != 'closed'"/>

                        <!-- Additional Transition Buttons from Completed State -->
                        <button name="action_in_progress" type="object" class="btn-info" string="Back to In Progress"
                                invisible="status != 'completed'"/>
                        <button name="action_closed" type="object" class="btn-danger" string="Mark as Closed"
                                invisible="status != 'completed'"/>


                        <!-- Normal Status Buttons (for New and In Progress states) -->
                        <button name="action_in_progress" type="object" class="btn-secondary" string="In Progress"
                                invisible="status != 'new'"/>
                        <button name="action_completed" type="object" class="btn-success" string="Completed"
                                invisible="status != 'in_progress'"/>
                        <button name="action_new" type="object" class="btn-primary" string="Back to New"
                                invisible="status in ('new', 'completed', 'closed')"/>
                        <button name="action_closed" type="object" class="btn-danger" string="Close"
                                invisible="status not in ('completed', 'new', 'in_progress')"/>
                        <field name="status" widget="statusbar" statusbar_visible="new,in_progress,completed,closed"/>
                    </header>
                    <div class="oe_title">
                        <label for="ref"/>
                        <h1>
                            <field name="ref" readonly="1"/>
                        </h1>
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="status in ('completed', 'closed')"/>
                        </h1>
                    </div>

                    <!-- Alert Message for Locked Tasks -->
                    <div class="alert alert-danger" role="alert" invisible="status not in ('completed', 'closed')">
                        <strong>⚠️ This task is locked!</strong>
                        Tasks marked as 'Completed' or 'Closed' cannot be edited.
                        Click the 'Unlock' button above to revert the status and make changes.
                    </div>

                    <group>
                        <group>
                            <field name="due_date" readonly="status in ('completed', 'closed')"/>
                            <field name="is_late" invisible="1"/>
                        </group>
                        <group>
                            <field name="assign_to" readonly="status in ('completed', 'closed')"/>
                            <field name="active" readonly="status in ('completed', 'closed')"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" readonly="status in ('completed', 'closed')"/>
                    </group>
                    <group>
                        <group>
                            <field name="estimated_time" readonly="status in ('completed', 'closed')"/>
                        </group>
                        <group>
                            <field name="total_time" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Timesheet Lines">
                            <field name="line_ids" readonly="status in ('completed', 'closed')">
                                <tree editable="bottom">
                                    <field name="num"/>
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="time"/>
                                </tree>
                            </field>
                            <div class="alert alert-info mt-3" role="alert">
                                <strong>Note:</strong>
                                Make sure the total time in the timesheet lines does not exceed the estimated time.
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="todo_task_search_view" model="ir.ui.view">
        <field name="name">todo task search</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="assign_to"/>

                <filter name="status_new" string="New" domain="[('status', '=', 'new')]"/>
                <filter name="status_in_progress" string="In Progress" domain="[('status', '=', 'in_progress')]"/>
                <filter name="status_completed" string="Completed" domain="[('status', '=', 'completed')]"/>

                <filter name="group_assign_to" string="Assign To" context="{'group_by':'assign_to'}"/>
                <filter name="group_status" string="Status" context="{'group_by':'status'}"/>
                <filter name="group_due_date" string="Due Date" context="{'group_by':'due_date'}"/>
            </search>
        </field>
    </record>


    <!-- Window Actions -->
    <record id="todo_task_action" model="ir.actions.act_window">
        <field name="name">ToDo Task</field>
        <field name="res_model">todo.task</field>
    </record>

    <!-- Server Actions -->
    <record id="todo_task_closed_server_action" model="ir.actions.server">
        <field name="name">Closed</field>
        <field name="model_id" ref="model_todo_task"/>
        <field name="binding_model_id" ref="model_todo_task"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_closed()
        </field>
    </record>

    <!-- Automated Actions -->
    <record id="check_due_data_cron" model="ir.cron">
        <field name="name">Todo Task: Check Due Data</field>
        <field name="model_id" ref="model_todo_task"/>
        <field name="state">code</field>
        <field name="code">
            model.check_due_date()
        </field>
        <field name="interval_type">days</field>
        <field name="interval_number">1</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

    <!-- Submenu: All Tasks that slide from navbar-->
    <menuitem id="all_task_menu_item"
              name="All Tasks"
              parent="todo_menu"
              action="todo_task_action"/>

</odoo>