<odoo>
    <!-- Define a new Category (Todo Task) for the todo task model -->
    <record id="todo_task_category" model="ir.module.category">
        <field name="name">Todo Task App</field>
    </record>


    <!-- Define a new Group for the (Todo Task Manager) -->
    <record id="todo_task_manager_group" model="res.groups">
        <field name="name">Todo Task Manager</field>
        <field name="category_id" ref="todo_module.todo_task_category"/>
    </record>

    <!--     Define a new Group for the (Todo Task User) -->
    <record id="todo_task_user_group" model="res.groups">
        <field name="name">Todo Task User</field>
        <field name="category_id" ref="todo_module.todo_task_category"/>
    </record>

