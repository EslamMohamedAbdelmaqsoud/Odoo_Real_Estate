<odoo>

    <!-- Tree View -->
    <record id="owner_tree_view" model="ir.ui.view">
        <field name="name">owner tree</field>
        <field name="model">owner</field>
        <field name="arch" type="xml">
            <tree multi_edit="1" create="1" edit="1" delete="1">
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="gender"/>
                <field name="description" optional="1"/>

            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="owner_form_view" model="ir.ui.view">
        <field name="name">owner form</field>
        <field name="model">owner</field>
        <field name="arch" type="xml">
            <form create="1" edit="1" delete="1">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General Info.">
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="gender"/>
                            <field name="description" required="1"/>
                        </group>

                        <group>
                            <field name="property_ids" widget="many2many_tags"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="owner_search_view" model="ir.ui.view">
        <field name="name">owner search</field>
        <field name="model">owner</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>


                <!--                <filter name="is_garden" string="With Garden" domain="[('garden', '=', True)]"/>-->
                <!--                <filter name="is_garden" string="Without Garden" domain="[('garden', '=', False)]"/>-->
                <!--                <filter name="is_garage" string="With Garage" domain="[('garage', '=', True)]"/>-->

                <!--                <filter name="group_garden" string="Garden" context="{'group_by':'garden'}"/>-->

            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="owner_action" model="ir.actions.act_window">
        <field name="name">Owner</field>
        <field name="res_model">owner</field>
    </record>

    <!-- Menu Items -->

    <menuitem id="owner_menu_item"
              name="Owners"
              parent="configuration_menu"
              action="owner_action"/>

</odoo>