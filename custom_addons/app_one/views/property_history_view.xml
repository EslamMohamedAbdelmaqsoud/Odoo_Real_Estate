<odoo>

    <!-- Tree View -->
    <record id="property_history_tree_view" model="ir.ui.view">
        <field name="name">property history tree</field>
        <field name="model">property.history</field>
        <field name="arch" type="xml">
            <tree class="header_custom" create="false" edit="false" delete="false">
                <field name="user_id"/>
                <field name="property_id"/>
                <field name="old_state"/>
                <field name="new_state"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="property_history_form_view" model="ir.ui.view">
        <field name="name">property history form</field>
        <field name="model">property.history</field>
        <field name="arch" type="xml">
            <form create="false" edit="false" delete="false">
                <sheet>
                    <group>

                        <group>
                            <field name="user_id"/>
                            <field name="property_id"/>
                        </group>
                        <group>
                            <field name="old_state"/>
                            <field name="new_state"/>
                            <field name="reason"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bedrooms">
                            <field name="line_ids" readonly="1">
                                <tree>
                                    <field name="area"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window Actions -->
    <record id="property_history_action" model="ir.actions.act_window">
        <field name="name">Property History</field>
        <field name="res_model">property.history</field>
    </record>


    <!-- Sub Menu Items Of Properties-->
    <menuitem id="property_history_menu_item"
              name="History"
              parent="properties_menu"
              action="property_history_action"/>

</odoo>