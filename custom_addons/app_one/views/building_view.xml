<odoo>

    <!-- Tree View -->
    <record id="building_tree_view" model="ir.ui.view">
        <field name="name">building tree</field>
        <field name="model">building</field>
        <field name="arch" type="xml">
            <tree class="header_custom">
                <field name="name"/>
                <field name="number"/>
                <field name="code"/>
                <field name="description"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="building_form_view" model="ir.ui.view">
        <field name="name">building form</field>
        <field name="model">building</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="General Info.">
                            <field name="name"/>
                            <field name="number"/>
                        </group>
                        <group string="Additional Info.">
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="building_search_view" model="ir.ui.view">
        <field name="name">building search</field>
        <field name="model">building</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="number"/>
                <field name="code"/>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="building_action" model="ir.actions.act_window">
        <field name="name">Building</field>
        <field name="res_model">building</field>
    </record>

    <!-- Menu Items -->

    <menuitem id="building_menu_item"
              name="Buildings"
              parent="properties_menu"
              action="building_action"/>

</odoo>