<odoo>

    <record id="change_state_wizard_form_view" model="ir.ui.view">
        <field name="name">chang state wizard form view</field>
        <field name="model">change.state.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="property_id" invisible="1"/>
                    <field name="state" required="1"/>
                    <field name="reason" required="1"/>
                </group>
                <footer>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                    <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Actions Wizard -->
    <record id="change_state_wizard_action" model="ir.actions.act_window">
        <field name="name">Change State</field>
        <field name="res_model">change.state.wizard</field>
        <field name="target">new</field>
        <field name="view_mode">form</field>
    </record>

</odoo>